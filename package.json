{
  "name": "@nkwib/promptregistry",
  "version": "0.2.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Turn a static prompt manifest into typed, greppable named imports with lockfile-gated integrity",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "promptregistry": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "screenshot": "tsx scripts/screenshot.ts",
    "prepublishOnly": "npm run typecheck && npm run build && npm test -- --run && npm run smoke"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "prompt",
    "llm",
    "typescript",
    "template",
    "type-safe",
    "manifest",
    "registry"
  ],
  "license": "MIT",
  "author": "Gabriele Magno <gabriele.magno@nearform.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nkwib/promptregistry.git"
  },
  "homepage": "https://promptregistry.pages.dev"
}
